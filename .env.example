# Create a local .env file and insert your newly rotated DART key.
DART_API_KEY=replace_with_your_rotated_key

# Use a long, random value for production platform access.
APP_ACCESS_PASSWORD=replace_with_a_long_random_password

# Use a separate random value so Streamlit can sign session cookies.
STREAMLIT_SERVER_COOKIE_SECRET=replace_with_a_different_random_value

# Public DNS hostname pointing to the deployment server.
DOMAIN=kquant.example.com

# Platform database password (letters and digits are easiest in DATABASE_URL).
POSTGRES_PASSWORD=replace_with_a_long_random_database_password

# Signs auth session/CSRF cookies. Generate: openssl rand -base64 48
AUTH_COOKIE_SECRET=replace_with_a_long_random_cookie_secret
# Self-service signup is CLOSED in production unless this is exactly "true".
AUTH_ALLOW_SIGNUP=false

# SMTP relay used for password-reset and email-verification delivery.
# Required in production (the auth service refuses to boot without a host).
# Works with any transactional provider (SES, Postmark, Resend, Mailgun, …)
# via its SMTP endpoint. SMTP_SECURE=true means implicit TLS (usually 465);
# false means STARTTLS on 587.
SMTP_HOST=replace_with_smtp_host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=replace_with_smtp_username
SMTP_PASSWORD=replace_with_smtp_password
# Sender shown on account email, e.g. "K-Quant <no-reply@YOUR_DOMAIN>".
MAIL_FROM=replace_with_mail_from_address

# The first-party login service uses server-side sessions. Cognito remains an
# optional alternative for deployments that already have an AWS user pool.
AUTH_MODE=session
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=replace_with_cognito_user_pool_id
COGNITO_APP_CLIENT_ID=replace_with_cognito_app_client_id
COGNITO_DOMAIN=replace_with_cognito_domain

# Stripe server-side values. Never prefix secret keys with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_ID=replace_with_stripe_recurring_price_id

# K-Quant production environment template.
# Copy to .env on the production host, then: chmod 600 .env && make deploy-check
#
# [GENERATE] = create with:  openssl rand -base64 48   (or the length noted)
# [USER]     = only you can supply this value.

# ── Domain ──────────────────────────────────────────────────────────────────
# [USER] Public hostname (no scheme). DNS A/AAAA record must point at the host.
DOMAIN=replace_with_your_domain

# ── Data stores ─────────────────────────────────────────────────────────────
# [GENERATE] >= 24 chars, letters and digits are easiest inside DATABASE_URL.
POSTGRES_PASSWORD=replace_with_a_long_random_database_password

# ── First-party authentication (AUTH_MODE=session, the default) ────────────
AUTH_MODE=session
# [GENERATE] >= 32 chars; signs session/CSRF cookies.
AUTH_COOKIE_SECRET=replace_with_a_long_random_cookie_secret
# [USER] Self-service signup stays CLOSED in production unless exactly "true".
AUTH_ALLOW_SIGNUP=false

# ── Account email delivery (required for AUTH_MODE=session) ────────────────
# [USER] SMTP endpoint of any transactional provider (SES, Postmark, Resend…).
SMTP_HOST=replace_with_smtp_host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=replace_with_smtp_username
SMTP_PASSWORD=replace_with_smtp_password
# [USER] e.g. "K-Quant <no-reply@YOUR_DOMAIN>"
MAIL_FROM=replace_with_mail_from_address

# ── Quant data sources ──────────────────────────────────────────────────────
# [USER] DART Open API key (rotate any key that ever appeared in source).
DART_API_KEY=replace_with_your_rotated_key

# ── Research/admin interface (analytics subdomain, optional) ───────────────
# [GENERATE] >= 20 chars. Gate password for the Streamlit research app.
APP_ACCESS_PASSWORD=replace_with_a_long_random_password
# [GENERATE] >= 32 chars, different from APP_ACCESS_PASSWORD.
STREAMLIT_SERVER_COOKIE_SECRET=replace_with_a_different_random_value

# ── Stripe billing (optional until paid plans launch) ───────────────────────
# [USER] Server-side only; never prefix with NEXT_PUBLIC_.
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_ID=replace_with_stripe_recurring_price_id

# ── Cognito (only if AUTH_MODE=cognito; ignore for first-party auth) ────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=replace_with_cognito_user_pool_id
COGNITO_APP_CLIENT_ID=replace_with_cognito_app_client_id
COGNITO_DOMAIN=replace_with_cognito_domain
